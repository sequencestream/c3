{
  "name": "code-creative-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,magenta \"pnpm -F @ccc/server dev\" \"pnpm -F @ccc/web dev\"",
    "build": "pnpm -F @ccc/web build && pnpm -F @ccc/server build",
    "start": "node server/dist/cli.cjs start",
    "binary": "pnpm build && pnpm -F @ccc/server binary",
    "release": "node scripts/release/release.mjs",
    "release:github": "node scripts/release/release-github.mjs",
    "release:build": "node scripts/release/release-build.mjs",
    "release:sign": "node scripts/release/sign.mjs",
    "release:notes": "node scripts/release/notes.mjs",
    "release:publish": "node scripts/release/publish.mjs",
    "release:gate": "node scripts/release/pregate.mjs",
    "release:smoke": "node scripts/release/smoke.mjs",
    "release:verify-dist": "node scripts/release/postgate.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "i18n:check": "node scripts/i18n/check.mjs",
    "i18n:check-freeze": "node scripts/i18n/check-freeze.mjs",
    "i18n:freeze": "node scripts/i18n/freeze.mjs",
    "i18n:unfreeze": "node scripts/i18n/unfreeze.mjs",
    "i18n:extract": "node scripts/i18n/extract.mjs",
    "i18n:gen-codes": "node scripts/i18n/gen-code-map.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "node scripts/e2e/run-all.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/eslint-plugin-vue-i18n": "^4.5.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.10",
    "concurrently": "^9.1.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.1.8",
    "vue": "^3.5.35",
    "vue-eslint-parser": "^10.4.0",
    "yaml-eslint-parser": "^2.0.0"
  }
}
